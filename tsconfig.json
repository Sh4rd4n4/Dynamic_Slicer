{
  "compilerOptions": {
    "target": "ES2020",
    "module": "ES2020",
    "moduleResolution": "bundler",
    "strict": true,
    "sourceMap": true,
    "experimentalDecorators": false,
    "skipLibCheck": true,
    "forceConsistentCasingInFileNames": true,
    "lib": ["DOM", "ES2020"],
    "types": []
  },
  "files": ["src/visual.ts", "src/settings.ts"],
  "include": ["src/**/*.ts", "src/**/*.d.ts"]
}
